# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For external deployments like Netlify/Vercel, use VITE_GEMINI_API_KEY.
VITE_GEMINI_API_KEY=AIzaSyDgv4q5Gu8_UF01El5Y92I0n-iGGAWoohc

GEMINI_API_KEY=AIzaSyDgv4q5Gu8_UF01El5Y92I0n-iGGAWoohc

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PEXELS_API_KEY: Required for interior image search.
# Prefix with VITE_ to expose to the client-side code.
VITE_PEXELS_API_KEY=PCFzYfyNbAxGXLXmkHanwYoc7w8DJXwSujxs8CWK6xctVujCM0ou00OB
